# Copie para .env na sua máquina (nunca commite .env).
# export APIFY_TOKEN=... também funciona.
#
# 1Password CLI: copie .env.1password.tpl → .env.local, troque REPLACE_VAULT/REPLACE_ITEM
# pelos nomes do cofre e do item, depois:
#   op run --env-file .env.local -- python scripts/run_pipeline.py
# (Documentação: https://developer.1password.com/docs/cli/secrets-environment-variables/)

APIFY_TOKEN=

APIFY_INSTAGRAM_ACTOR_ID=
APIFY_TIKTOK_ACTOR_ID=
APIFY_X_ACTOR_ID=

TWITTER_BEARER_TOKEN=

YOUTUBE_API_KEY=
