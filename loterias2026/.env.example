# Opcional: copie para .env se preferir arquivo local (nunca commite .env com segredos).
# O token também pode ser só variável de ambiente do sistema: export APIFY_TOKEN=...

# Apify — token em https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_RTbF3oQY7X92gvgyUag1LlbR68Pyjr4bdd3T

# IDs dos Actors (opcional): o script já usa por padrão apify/instagram-scraper,
# clockworks/tiktok-scraper e apidojo/twitter-scraper-lite.
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_TIKTOK_ACTOR_ID=
APIFY_X_ACTOR_ID=

# X API v2 (opcional) — Bearer Token (projeto no developer portal)
TWITTER_BEARER_TOKEN=

# YouTube Data API v3 (opcional) — enriquecimento além do RSS/yt-dlp
YOUTUBE_API_KEY=
