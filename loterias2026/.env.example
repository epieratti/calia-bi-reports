# Copie para .env e preencha o que for usar (nunca commite .env com segredos).

# Apify (Instagram / TikTok / X — conforme atores que você configurar no console)
# https://apify.com — token em Account → Integrations → API token
APIFY_TOKEN=

# IDs dos Actors Apify (ex.: apify/instagram-scraper, clockworks/tiktok-scraper, etc.)
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_TIKTOK_ACTOR_ID=
APIFY_X_ACTOR_ID=

# X API v2 (opcional) — Bearer Token (projeto no developer portal)
TWITTER_BEARER_TOKEN=

# YouTube Data API v3 (opcional) — enriquecimento além do RSS/yt-dlp
YOUTUBE_API_KEY=
